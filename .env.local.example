# ============================================================
# OBRIGATÓRIAS — o app não inicia sem estas.
# ============================================================

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Chave service-role do Supabase. Ignora o RLS; usada somente pelas
# rotas server-side (o webhook, o motor de automações e o caminho de
# autenticação da API pública — veja docs/public-api.md). Mantenha
# esta chave em segredo — nunca a cole em código client-side.
#
# Nota: a API pública (/api/v1) não precisa de nenhuma variável de
# ambiente nova. As chaves de API são criadas no painel (Settings →
# API keys) e armazenadas com hash no banco de dados; esta chave
# service-role é o que permite ao caminho de autenticação buscar uma
# chave apresentada sem uma sessão de usuário.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Criptografia do token do WhatsApp (64 caracteres hex = 32 bytes,
# AES-256-GCM). Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotacionar este valor torna órfão todo token criptografado com a
# chave anterior — os usuários precisam salvar novamente as
# configurações do WhatsApp para reconectar.
ENCRYPTION_KEY=your-64-char-hex-key-here

# Meta App Secret (Meta for Developers → App Settings → Basic).
# Verifica a assinatura HMAC-SHA256 em cada POST de webhook recebido.
# Obrigatória — sem ela o webhook rejeita todas as requisições.
META_APP_SECRET=your-meta-app-secret

# ============================================================
# RECOMENDADAS — existem padrões seguros, mas você vai querer
# configurá-las.
# ============================================================

# URL pública canônica deste deployment (esquema + host, sem barra
# no final). Usada para o sitemap e imagens OG. Rotas que precisam de
# uma URL auto-referencial (links de convite de
# /api/account/invitations, qualquer futuro link enviado por e-mail)
# derivam a origem a partir da própria requisição, então esta
# variável só é necessária quando a origem derivada da requisição
# estaria errada — por exemplo, ao gerar links a partir de um cron job
# ou de um worker em background que não tem uma requisição de entrada.
NEXT_PUBLIC_SITE_URL=https://crm.example.com

# Idioma padrão do servidor para visitantes que ainda não escolheram
# um idioma (primeira visita, ou navegador bloqueando cookies).
# Depois da primeira escolha, o idioma passa a ser lido do cookie
# NEXT_LOCALE (definido em Configurações → Aparência) — esta variável
# não fixa mais o idioma de toda a instância.
# Valores aceitos: pt-BR (padrão do projeto), en.
NEXT_PUBLIC_APP_LOCALE=pt-BR

# ============================================================
# OPCIONAIS — necessárias apenas se você usar o recurso.
# ============================================================

# Allow-list de defesa em profundidade para os hostnames que
# /api/account/invitations pode publicar em URLs de convite.
# Separados por vírgula, sem esquema, sem porta (apenas hostnames).
#
# Por que isso existe: quando NEXT_PUBLIC_SITE_URL não está definida,
# as URLs de convite são derivadas dos cabeçalhos `Host` /
# `X-Forwarded-Host` da requisição recebida. Em um deploy típico
# atrás de proxy, o proxy define esses cabeçalhos com o seu hostname
# canônico e eles são confiáveis. Em um deployment *sem proxy*,
# exposto diretamente à internet pública, um atacante poderia fazer
# um POST direto à API com um `Host: phishing.example` falsificado e
# receber uma URL de convite apontando para o site dele.
#
# Quando esta variável está definida, hostnames que não estão na
# lista são rejeitados (a requisição cai no fallback wacrm.tech com
# um console.warn). Quando não está definida, o comportamento
# permanece igual ao de versões anteriores — o host derivado da
# requisição é confiável.
#
# A maioria dos operadores não precisa disso: definir
# NEXT_PUBLIC_SITE_URL com sua URL canônica já fixa os links de
# convite nela. Isto é para operadores que querem cinto e suspensório
# ou que rodam setups multi-tenant onde uma única instância do app
# serve vários hostnames.
#
# Exemplo:
#   ALLOWED_INVITE_HOSTS=crm.example.com,crm-staging.example.com

# Segredo compartilhado que protege GET /api/automations/cron.
# Obrigatório se você usar passos de espera (Wait) em automações (um
# pinger agendado processa as execuções pendentes). Gere uma string
# longa e aleatória com:
#   openssl rand -hex 32
# Veja docs/automations-and-cron.md.
# AUTOMATION_CRON_SECRET=generate-a-long-random-string

# Meta App ID (Meta for Developers → App Settings → Basic).
# Obrigatório para criar/editar templates de mensagem com um cabeçalho
# do tipo IMAGE: a Meta só aceita um handle de mídia via
# Resumable-Upload (não uma URL simples) como amostra do cabeçalho, e
# esse upload é vinculado ao app. Sem ele, o envio de template com
# cabeçalho de imagem retorna um erro claro; templates somente de
# texto/corpo não são afetados. Use em conjunto com META_APP_SECRET.
# META_APP_ID=your-meta-app-id

# Quando "true", POST /api/whatsapp/templates/submit pula a chamada à
# Meta e armazena o registro com um meta_template_id sintético
# `dry-run-<uuid>`. Defina isto no CI e no desenvolvimento local para
# poder testar toda a interface de templates sem uma WABA real. Deixe
# sem definir (ou "false") em produção.
# WHATSAPP_TEMPLATES_DRY_RUN=true

# ------------------------------------------------------------------
# Assistente de respostas com IA (opcional)
# ------------------------------------------------------------------
# O assistente de IA é bring-your-own-key: cada conta cola sua própria
# chave OpenAI ou Anthropic em Settings → AI Assistant. A chave é
# armazenada criptografada com AES-256-GCM usando ENCRYPTION_KEY
# (acima) — NÃO existe uma variável de ambiente global de chave de
# provedor, e nada aqui é obrigatório para o recurso funcionar. As
# duas variáveis abaixo apenas ajustam o comportamento.
#
# A base de conhecimento de IA (migration 030) usa busca de texto
# completo do Postgres por padrão. A busca semântica opcional precisa
# da extensão `pgvector` — a migration 030 executa
# `CREATE EXTENSION IF NOT EXISTS vector` (o Supabase já a tem
# disponível) — além de uma chave de embeddings por conta, configurada
# em Settings → AI Assistant. Ainda assim, nenhuma variável de
# ambiente é necessária.

# Timeout por chamada para requisições ao provedor, em milissegundos.
# Padrão 30000.
# AI_REQUEST_TIMEOUT_MS=30000

# Quantas mensagens de texto recentes de uma conversa enviar ao modelo
# como contexto (rascunho + resposta automática). Padrão 20.
# AI_CONTEXT_MESSAGE_LIMIT=20
